# ============================================
# Jira 연결 설정 (필수)
# ============================================
# Jira 인스턴스 URL
JIRA_URL=https://your-domain.atlassian.net

# Jira 계정 이메일
JIRA_EMAIL=your-jira-email@example.com

# Jira API Token (https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_TOKEN=ATATT3xFfGF0...

# Jira 프로젝트 키 (예: AEGIS, PROJ)
JIRA_PROJECT_KEY=YOUR_PROJECT


# ============================================
# Confluence 연결 설정 (DoD Automation 사용 시 필수)
# ============================================
# Confluence 인스턴스 URL
# - Jira와 같은 도메인: https://your-domain.atlassian.net/wiki
# - 별도 인스턴스: https://wiki.your-company.com
CONFLUENCE_URL=https://your-domain.atlassian.net/wiki

# Confluence 계정 이메일 (Jira와 다를 수 있음)
CONFLUENCE_EMAIL=your-confluence-email@example.com

# Confluence API Token (Jira와 다를 수 있음)
CONFLUENCE_API_TOKEN=ATATT3xFfGF0...


# ============================================
# 서버 설정
# ============================================
# API 서버 포트
API_PORT=5174

# CORS 허용 오리진 (프론트엔드 URL)
APP_ORIGIN=http://localhost:5173


# ============================================
# 설정 가이드
# ============================================
# 1. API Token 발급:
#    https://id.atlassian.com/manage-profile/security/api-tokens
#
# 2. Jira와 Confluence 계정이 같은 경우:
#    - CONFLUENCE_EMAIL = JIRA_EMAIL
#    - CONFLUENCE_API_TOKEN = JIRA_API_TOKEN
#    - CONFLUENCE_URL = JIRA_URL + /wiki
#
# 3. Jira와 Confluence 계정이 다른 경우:
#    - 각각 별도로 설정
#    - 각각 별도 API Token 발급
#
# 4. Confluence만 사용하는 경우:
#    - JIRA_* 항목도 필수 (티켓 생성 기능에 사용)
#
# 5. 보안 주의:
#    - .env 파일은 절대 Git에 커밋하지 마세요!
#    - .gitignore에 .env가 포함되어 있는지 확인하세요.
